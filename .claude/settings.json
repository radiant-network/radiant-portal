{
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(**/.env)",
      "Read(.env.*)",
      "Read(**/.env.*)",
      "Edit(.env)",
      "Edit(**/.env)",
      "Edit(.env.*)",
      "Edit(**/.env.*)",
      "Write(.env)",
      "Write(**/.env)",
      "Write(.env.*)",
      "Write(**/.env.*)"
    ],
    "allow": ["Read((**/.env.template)", "Edit((**/.env.template)"]
  }
}
