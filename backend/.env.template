# ==============================================================================
# COMMON — StarRocks (analytical) + PostgreSQL (operational) + logging.
# Read by the API server, the worker, and the provisioning CLIs.
# ==============================================================================
DB_USERNAME=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=9030
DB_NAME=test_db
DB_SSL_MODE=skip-verify              # skip-verify | preferred | true | disable (DB_SSL_CA takes precedence)
DB_SSL_CA=
DB_SLOW_QUERY_THRESHOLD_MS=500

PGUSER=radiant
PGPASSWORD=radiant
PGHOST=localhost
PGPORT=5432
PGDATABASE=radiant
PGSSLMODE=disable
PGSSLROOTCERT=                       # CA path; only needed when PGSSLMODE requires cert verification

LOG_LEVEL=INFO                       # debug | info | warn | error

# ==============================================================================
# API SERVER (cmd/api)
# ==============================================================================
API_PORT=8090
CORS_ALLOWED_ORIGINS=*
SHUTDOWN_TIMEOUT_SECONDS=30

# On startup, recreate every tenant's StarRocks views when a migration changed the schema.
VIEW_REFRESH_ON_STARTUP_ENABLED=false

PUBMED_BASE_URL=https://api.ncbi.nlm.nih.gov

# S3 / MinIO — presigned URLs for case documents + IGV files.
AWS_ENDPOINT_URL=http://localhost:9000
AWS_REGION=us-east-1
AWS_USE_SSL=false
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=password
S3_PRESIGNED_URL_EXPIRE=60m

# ==============================================================================
# WORKER (cmd/worker)
# ==============================================================================
POLL_INTERVAL_MS=1000
CLEAN_UP_INTERVAL_POLL_HOUR=24
PROBE_PORT=9999

# ==============================================================================
# KEYCLOAK — identity provider (the API validates bearer JWTs against this realm)
# ==============================================================================
KEYCLOAK_HOST=http://localhost:8080
KEYCLOAK_REALM=master

# ==============================================================================
# MULTI-TENANT StarRocks + RANGER ENFORCEMENT
#   Per-tenant view DBs (<code>_tenant), the shared base DB, and mysql-proxy per-user reads.
#   Enable TENANT_VIEWS_READ_ENABLED and STARROCKS_PROXY_READ_ENABLED TOGETHER, and only once
#   the StarRocks FE has access_control=ranger and the proxy sidecar is deployed.
# ==============================================================================
SHARED_DATABASE=radiant              # shared base DB: cross-tenant reference/genomic tables
TENANT_VIEWS_READ_ENABLED=false      # reads resolve <code>_tenant views instead of radiant_jdbc
STARROCKS_PROXY_READ_ENABLED=false   # run /:tenant reads as the user through mysql-proxy
STARROCKS_PROXY_ADDR=127.0.0.1:9031  # mysql-proxy address the API dials (required when proxy-read is on)

# ==============================================================================
# PROVISIONING CLIs (cmd/createuser, cmd/create-tenant, cmd/refresh-tenants)
#   Not read by the API server at runtime.
# ==============================================================================
# Keycloak admin (client-credentials) — createuser upserts Keycloak users
KEYCLOAK_ADMIN_CLIENT_ID=kcadmin
KEYCLOAK_ADMIN_CLIENT_SECRET=admin

# StarRocks JWT config baked into each created user. JWKS_URL must be reachable FROM the
# StarRocks FE (in-network Keycloak); REQUIRED_ISSUER must equal the token's `iss` (host-facing
# Keycloak URL); REQUIRED_AUDIENCE must match the `aud` mapped for the client.
STARROCKS_JWT_JWKS_URL=http://keycloak:8080/realms/CQDG/protocol/openid-connect/certs
STARROCKS_JWT_REQUIRED_ISSUER=http://localhost:8080/realms/CQDG
STARROCKS_JWT_REQUIRED_AUDIENCE=radiant

# Ranger admin — create-tenant / refresh-tenants provision roles + policies
RANGER_URL=http://localhost:6080
RANGER_ADMIN_USER=admin
RANGER_ADMIN_PASSWORD=rangerR0cks!

# ==============================================================================
# mysql-proxy (cmd/mysql-proxy) — SEPARATE binary/deployment (sidecar next to the API).
#   Listed for completeness; in production these live in the proxy's own env, not the API's.
# ==============================================================================
LISTEN_ADDR=:9031                    # cleartext client port (loopback/sidecar only — never expose)
STARROCKS_ADDR=localhost:9030        # StarRocks FE the proxy dials (its own hop; not 127.0.0.1 in-cluster)
STARROCKS_SSL_CA=                    # CA bundle to verify StarRocks' cert; UNSET = skip verification (dev only) — SET in QA/prod
# PROBE_PORT=9998                    # proxy health probe; distinct default from the worker's 9999 (uncomment if co-located)
